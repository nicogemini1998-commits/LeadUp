# LeadUp frontend (Vite) — environment variables
# Copy to `.env` and adjust as needed. NEVER commit your real `.env`.

# Dev server port
VITE_PORT=5174

# Backend API base URL (used by the Vite dev proxy)
VITE_API_URL=http://localhost:8002

# Optional external booking/calendar link opened when a lead is marked "closed".
# Leave empty to disable the auto-open behavior.
VITE_BOOKING_URL=
