# ─────────────────────────────────────────────────────────────────────────────
# LeadUp backend — environment variables
# Copy to `.env` and fill in real values. NEVER commit your real `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- Security (REQUIRED) ---
# Generate a strong random secret, e.g. `openssl rand -hex 32`
JWT_SECRET=replace_with_a_long_random_secret

# --- Database (REQUIRED) ---
# PostgreSQL connection string. Works with any Postgres host (Supabase, RDS, local, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/leadup

# --- AI enrichment (Anthropic Claude) ---
# Used to score leads and generate hooks, opening lines and sales reports.
ANTHROPIC_API_KEY=

# --- Lead source: Lusha (primary) ---
# B2B contact data provider used to source and reveal contacts.
LUSHA_API_KEY=

# --- Lead source: Apify Google Maps (optional, secondary) ---
# Only needed if you enable the Google Maps scraping endpoints.
APIFY_API_KEY=

# --- Server ---
PORT=8002
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5174

# --- External booking link (optional) ---
# Opened in a new tab when a lead is marked as "closed". Leave empty to disable.
BOOKING_URL=

# --- Email notifications (optional, SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
LOW_LEADS_THRESHOLD=2

# --- Observability (optional, Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
