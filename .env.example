# ─────────────────────────────────────────────────────────────────────────────
# LeadUp — root environment variables (for docker-compose)
# Copy to `.env` and fill in real values. NEVER commit your real `.env`.
# Per-service variables also live in backend/.env.example and frontend/.env.example
# ─────────────────────────────────────────────────────────────────────────────

# --- Security (REQUIRED) ---
# Generate a strong random secret, e.g. `openssl rand -hex 32`
JWT_SECRET=replace_with_a_long_random_secret

# --- Database (REQUIRED) ---
# PostgreSQL connection string. Any Postgres host works.
# Local docker-compose example:
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/leadup

# If you use Supabase (a hosted Postgres) instead of the bundled container,
# point DATABASE_URL at your Supabase connection string. The optional vars
# below are only needed if you later add a Supabase client; the backend itself
# only requires DATABASE_URL.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Local Postgres container credentials (docker-compose) ---
DB_USER=postgres
DB_PASSWORD=postgres

# --- AI enrichment (Anthropic Claude) ---
ANTHROPIC_API_KEY=

# --- Lead source: Lusha (primary) ---
LUSHA_API_KEY=

# --- Lead source: Apify Google Maps (optional, secondary) ---
APIFY_API_KEY=

# --- Server ---
PORT=8002
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5174

# --- Frontend (Vite) ---
VITE_PORT=5174
VITE_API_URL=http://localhost:8002

# --- External booking link (optional) ---
BOOKING_URL=
VITE_BOOKING_URL=

# --- Email notifications (optional, SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
LOW_LEADS_THRESHOLD=2

# --- Observability (optional, Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
